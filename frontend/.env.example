# ===========================================================================
# Frontend environment variables (Vite)
# Copy to .env.local for local dev. NEVER commit real values.
# In Vercel, set these in Project Settings -> Environment Variables.
# NOTE: Vite exposes anything prefixed with VITE_ to the browser bundle.
# Firebase web config below is PUBLIC by design (not a secret).
# ===========================================================================

# Base URL of the Spring Boot backend (no trailing slash).
# Local:  http://localhost:8080
# Prod:   https://life-dashboard-backend-xxxx.a.run.app
VITE_API_BASE_URL=http://localhost:8080

# Firebase Web SDK config (from Firebase console -> Project settings -> Your apps)
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
# (Optional) Storage bucket; defaults to <projectId>.appspot.com
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Web Push (FCM) for chat notifications.
#   Sender ID = GCP project number (Firebase console -> Project settings -> Cloud Messaging).
#   VAPID key = "Web Push certificates" key pair on that same page.
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_VAPID_KEY=your-web-push-vapid-public-key

# (Optional) Base URL for the AI stock-research JSON data. Defaults to the
# public stock-radar GitHub raw path; override to point at your own fork.
# VITE_STOCK_DATA_BASE=https://raw.githubusercontent.com/<owner>/stock-radar/main/public
