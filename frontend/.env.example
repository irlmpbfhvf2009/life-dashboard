# ===========================================================================
# Frontend environment variables (Vite)
# Copy to .env.local for local dev. NEVER commit real values.
# In Vercel, set these in Project Settings -> Environment Variables.
# NOTE: Vite exposes anything prefixed with VITE_ to the browser bundle.
# Firebase web config below is PUBLIC by design (not a secret).
# ===========================================================================

# Base URL of the Spring Boot backend (no trailing slash).
# Local:  http://localhost:8080
# Prod:   https://life-dashboard-backend-xxxx.a.run.app
VITE_API_BASE_URL=http://localhost:8080

# Firebase Web SDK config (from Firebase console -> Project settings -> Your apps)
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
