# ===========================================================================
# Backend environment variables (Spring Boot / Cloud Run)
# Copy to .env for local dev. NEVER commit the real .env.
# On Cloud Run these are set as service env vars / secrets (see docs/deployment.md).
# ===========================================================================

# --- Neon PostgreSQL ---
# Use the JDBC URL form. Neon requires SSL.
# Example: jdbc:postgresql://ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=jdbc:postgresql://<neon-host>/<db>?sslmode=require
DATABASE_USERNAME=<neon-user>
DATABASE_PASSWORD=<neon-password>

# --- Firebase Admin (token verification) ---
FIREBASE_PROJECT_ID=your-firebase-project-id
# Paste the FULL service-account JSON as a single line (escaped) or use a
# Secret Manager reference on Cloud Run. Do NOT hard-code this in source.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# --- Server ---
# Cloud Run injects PORT automatically; 8080 is the local default.
PORT=8080
